PORT=3000
OCR_PROVIDER=paddle
USE_MOCK_OCR=false
PADDLE_PYTHON=.venv/bin/python
PADDLE_PDX_CACHE_HOME=.paddle-cache
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_HTML_MODEL=qwen2.5vl:7b

# Optional OpenAI-compatible local vision endpoints for HTML reconstruction.
# Keep PaddleOCR and Ollama as-is; use these routes to compare newer vision models:
# POST /reconstruct-html/qwen
# POST /reconstruct-html/glm
# POST /reconstruct-html/gemini
QWEN_VL_URL=http://127.0.0.1:11434/v1/chat/completions
QWEN_VL_MODEL=qwen2.5vl:7b
QWEN_VL_API_KEY=

GLM_VL_URL=http://127.0.0.1:11434/v1/chat/completions
GLM_VL_MODEL=glm-ocr:latest
GLM_VL_API_KEY=

GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/interactions
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
